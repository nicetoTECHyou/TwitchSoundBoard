# TwitchSoundBoard – lokale Konfiguration
# Kopiere diese Datei als .env und trage deine Daten ein.
# =============================================

# Twitch Chat (optional - ohne geht auch!)
# Bot-Token erstellen: https://twitchapps.com/tmi/
TWITCH_CHANNEL=dein_kanalname
TWITCH_BOT_TOKEN=oauth:dein_token_hier

# Twitch Client ID (optional, fuer erweiterte Features)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Ports (Standard)
PORT=3000
WS_PORT=3001
