# =============================================
# TwitchSoundBoard – Umgebungsvariablen
# =============================================
# Kopiere diese Datei als .env und trage deine Daten ein.
# =============================================

# Twitch Developer Portal (https://dev.twitch.tv/console)
TWITCH_CLIENT_ID=deine_client_id_hier
TWITCH_CLIENT_SECRET=dein_client_secret_hier

# Twitch-Broadcaster-Kanalname
TWITCH_CHANNEL=dein_kanalname

# Twitch-Broadcaster-UserID (optional, wird automatisch ermittelt)
TWITCH_BROADCASTER_ID=

# OAuth-Token für den Chat-Bot (optional, nur wenn du einen separaten Bot nutzt)
# Generiere hier: https://twitchapps.com/tmi/
TWITCH_BOT_TOKEN=

# Server-Port (Standard: 3000)
PORT=3000

# OBS WebSocket-Port (Standard: gleich wie PORT, das Overlay verbindet sich per WS)
WS_PORT=3001

# ngrok / Öffentliche URL für Twitch EventSub Webhooks
# WICHTIG: Twitch benötigt eine öffentliche HTTPS-URL für EventSub!
# Nutze z.B. ngrok: ngrok http 3000
PUBLIC_URL=https://dein-ngrok-url.ngrok-free.app

# EventSub Secret (eigener String, mind. 10 Zeichen)
EVENTSUB_SECRET=mein_geheimes_eventsub_passwort
